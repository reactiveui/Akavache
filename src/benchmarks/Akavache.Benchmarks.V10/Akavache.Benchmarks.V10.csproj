<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net9.0</TargetFrameworks>
    <IsPackable>false</IsPackable>
    <!-- Benchmarks for legacy V10 APIs which use reflection by design - not AOT-compatible -->
    <IsAotCompatible>false</IsAotCompatible>
    <EnableTrimAnalyzer>false</EnableTrimAnalyzer>
    <EnableAotAnalyzer>false</EnableAotAnalyzer>
    <!-- Fossilised v10 comparison benchmark: references the published Akavache.Sqlite3 10.2.41
         whose transitive deps (sqlite-net-pcl, bundle_green) are no longer declared in the main
         CPM set. Disable transitive pinning so restore uses the versions the v10 package itself
         requested. -->
    <CentralPackageTransitivePinningEnabled>false</CentralPackageTransitivePinningEnabled>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" />
    <PackageReference Include="Akavache.Sqlite3" VersionOverride="12.0.12" />
    <PackageReference Include="SQLitePCLRaw.bundle_green" VersionOverride="2.1.11" />
  </ItemGroup>

</Project>
