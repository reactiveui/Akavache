<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(AkavacheBaseTargets)</TargetFrameworks>
    <LangVersion>preview</LangVersion>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Akavache.Drawing\Akavache.Drawing.csproj" />
    <ProjectReference Include="..\..\Akavache.SystemTextJson\Akavache.SystemTextJson.csproj" />
    <ProjectReference Include="..\..\Akavache.SystemTextJson.Bson\Akavache.SystemTextJson.Bson.csproj" />
    <ProjectReference Include="..\..\Akavache.Core\Akavache.csproj" />
    <ProjectReference Include="..\..\Akavache.Http\Akavache.Http.csproj" />
    <ProjectReference Include="..\..\Akavache.EncryptedSqlite3\Akavache.EncryptedSqlite3.csproj" />
    <ProjectReference Include="..\..\Akavache.NewtonsoftJson\Akavache.NewtonsoftJson.csproj" />
    <ProjectReference Include="..\..\Akavache.Sqlite3\Akavache.Sqlite3.csproj" />
    <ProjectReference Include="..\..\Akavache.Settings\Akavache.Settings.csproj" />
    <ProjectReference Include="..\..\Akavache.V10toV11\Akavache.V10toV11.csproj" />
  </ItemGroup>

  <!-- Shared test infrastructure from tests/shared/. -->
  <ItemGroup>
    <Compile Include="..\shared\Helpers\*.cs" Link="Helpers\%(Filename)%(Extension)" />
    <Compile Include="..\shared\Mocks\*.cs" Exclude="..\shared\Mocks\InMemoryAkavacheConnection.cs" Link="Mocks\%(Filename)%(Extension)" />
    <Compile Include="..\shared\TestBases\*.cs" Exclude="..\shared\TestBases\BlobCacheDownloadTestsBase.cs" Link="TestBases\%(Filename)%(Extension)" />
  </ItemGroup>

</Project>
