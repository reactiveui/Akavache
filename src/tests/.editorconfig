# Inherits from ../../.editorconfig — no `root = true` here on purpose so the
# rules in the repo-level config still apply. This file only lists overrides
# that are tests-specific.

[*.cs]

# Test types are internal to the test runner and don't need DebuggerDisplay
# attributes; suppress here so the rule still applies to public production
# types.
dotnet_diagnostic.RCS1223.severity = none # Mark publicly visible type with DebuggerDisplay attribute — not useful for test fixtures

# Test fakes/mocks deliberately throw NotImplementedException from members the test doesn't exercise; this is intentional.
dotnet_diagnostic.RCS1079.severity = none # Implement the functionality instead of throwing new NotImplementedException — deliberate in test fakes

# IDE0200 (lambda can be removed) is unsafe for TUnit Assert.That(...).Throws<T>() / .ThrowsNothing() patterns.
# Method-group conversion binds to a different Assert.That overload that does NOT invoke the delegate,
# so the throw assertion silently misses (or the no-throw assertion silently passes). Keep the explicit lambda.
dotnet_diagnostic.IDE0200.severity = none # Lambda expression can be removed — required for TUnit Assert.That throw-matchers
